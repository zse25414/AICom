# Lumina AI — 環境變數範本
# 用法：cp .env.example .env  後填入實際值（.env 已 gitignore，勿提交）

# ══════════════════════════════════════════
# 開發預設（本機 npm run dev / dev:all）
# ══════════════════════════════════════════

# ── 必要密鑰（開發可用佔位；生產必須換成長隨機字串）──
JWT_SECRET=change-me-to-a-long-random-string
PIN_SALT=change-me-pin-salt
RAG_API_KEY=change-me-rag-api-key
DEEPSEEK_API_KEY=sk-your-deepseek-key

# ── 伺服器 ──
PORT=3001
NODE_ENV=development
ALLOWED_ORIGINS=http://localhost:3456,http://127.0.0.1:3456

# ── RAG 服務 ──
RAG_SERVICE_URL=http://127.0.0.1:8000
# RAG_HOST=0.0.0.0                  # RAG 容器內監聽（Docker）
# RAG_PORT=8000
# EMBEDDING_PROVIDER=local          # local | openai | auto
# LOCAL_EMBED_MODEL=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2

# ── RAG 檢索調參（選用；預設值見 rag_service/config.py）──
# RAG_CHUNK_SIZE=420                # 切塊字數
# RAG_CHUNK_OVERLAP=80              # 切塊重疊
# RAG_VECTOR_TOP_K=6                # 向量檢索取前 K
# RAG_BM25_TOP_K=6                  # BM25 檢索取前 K
# RAG_FUSION_TOP_K=5                # 融合後取前 K
# RAG_MIN_RELEVANCE_SCORE=0.01     # 低於此分數的段落捨棄
# RAG_ALLOW_DELETE_GENERAL=1        # 允許刪除 general 知識庫（預設禁止）
# RAG_INDEX_TIMEOUT_MS=12000        # API 端等待索引完成的上限（逾時轉背景）
# DEEPSEEK_API_BASE=https://api.deepseek.com   # LLM API base（RAG 服務端）
# DEEPSEEK_MODEL=deepseek-chat
# OPENAI_API_KEY=                   # EMBEDDING_PROVIDER=openai 時需要
# OPENAI_MODEL=

# ── LLM Proxy（選用）──
# ALLOWED_LLM_API_BASES=https://api.deepseek.com,https://api.deepseek.com/v1   # client 可指定的 api_base allowlist

# ── MongoDB（開發選用：未設定則用本機 JSON 檔）──
# MONGODB_URI=mongodb+srv://user:pass@cluster.mongodb.net/?appName=Lumina
# MONGODB_DB=lumina
# MONGODB_TLS_INSECURE=1            # 僅開發除錯用

# ── 安全旗標（開發可選）──
# LUMINA_ENFORCE_SECRETS=1          # 強制檢查 JWT/PIN/RAG/DeepSeek 密鑰
# REQUIRE_ENTERPRISE_AUTH=1         # 團隊 API 強制 JWT + memberId 綁定
# REQUIRE_MONGODB=1                 # 禁止 MongoDB 失敗後降級 JSON
# ALLOW_ANONYMOUS_AI=1              # 允許未登入呼叫 /api/chat、/api/rag

# ── JWT ──
# JWT_EXPIRES_SEC=604800

# ══════════════════════════════════════════
# 生產必填（NODE_ENV=production 或 docker-compose.prod.yml）
# ══════════════════════════════════════════
# 下列在 production 缺一不可；compose prod 會以 ${VAR:?required} 強制：
#
#   JWT_SECRET          — JWT 簽章（長隨機字串）
#   PIN_SALT            — 主管 PIN 雜湊鹽
#   RAG_API_KEY         — RAG 閘道金鑰（API 與 RAG 服務共用）
#   DEEPSEEK_API_KEY    — DeepSeek AI 代理
#   MONGODB_URI         — 生產禁止 JSON 降級，必須 Mongo
#   ALLOWED_ORIGINS     — 逗號分隔前端 origin（例：https://app.example.com）
#
# 建議一併設定：
#   NODE_ENV=production
#   LUMINA_ENFORCE_SECRETS=1
#   REQUIRE_ENTERPRISE_AUTH=1
#   REQUIRE_MONGODB=1
#   RAG_SERVICE_URL=http://rag:8000   # Docker 內部網路
